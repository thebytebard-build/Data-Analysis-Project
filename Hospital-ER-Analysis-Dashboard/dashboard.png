<p data-start="2383" data-end="2393"><code data-start="2383" data-end="2391">SUMIFS</code></p>
</li>
<li data-section-id="11eu69e" data-start="2394" data-end="2407">
<p data-start="2396" data-end="2407"><code data-start="2396" data-end="2405">XLOOKUP</code></p>
</li>
<li data-section-id="1jahp8o" data-start="2408" data-end="2425">
<p data-start="2410" data-end="2425"><code data-start="2410" data-end="2423">INDEX-MATCH</code></p>
</li>
<li data-section-id="17n6w87" data-start="2426" data-end="2434">
<p data-start="2428" data-end="2434"><code data-start="2428" data-end="2432">IF</code></p>
</li>
</ul>
<p data-start="2436" data-end="2456">👉 Only where needed</p>
