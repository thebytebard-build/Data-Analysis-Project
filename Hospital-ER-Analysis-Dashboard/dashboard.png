    }

    & > header {
      font-weight: 700;
      color: ${t2};
      font-size: 10px;
      line-height: 100%;
      padding: 0 24px;
      text-transform: uppercase;
    }

    & > h2 {
      color: ${p};
      font-size: 16px;
      font-weight: 700;
      line-height: 22px;
      margin-top: 3px;
      padding: 0 24px;
      letter-spacing: -0.25px;
    }

    & > p {
      margin-top: 17px;
      color: ${o0};
      font-family: Inter, sans-serif;
      font-size: 14px;
      line-height: 20px;
      padding: 0 24px;

      & > span {
        font: inherit;
        color: inherit;
        margin-top: 20px;
        display: inline-block;
      }
    }

    & > footer {
      background: ${r0};
      display: flex;
      padding: 16px 24px;
      justify-content: space-between;
      align-items: center;
      align-self: stretch;
      margin-top: 17px;
      border-top: 1px solid ${c0};
      border-bottom-left-radius: 8px;
      border-bottom-right-radius: 8px;

    }

    & .__skip {
      font-weight: 500;
      font-size: 12px;
      line-height: 20px;
      color: ${t2};
    }

    & .__nextStep {
      color: ${p};
      background: ${v2};
      padding: 0 12px;
      height: 40px;
      border-radius: 8px;
      min-width: 80px;
    }
  }
`,B0=`
    .onboardingWrapper:before {
        content: '';
        display: block;
        position: fixed;
        z-index: 10;
        inset: 0;
        background: ${l0};
    }
    .settings-manager-wrapper[class*="_step-"] {
      .settings-manager-icon {
        z-index: 15;
      }
      
      .js-active-ad-blocking-icon{
        display: block!important;
      }
      
      .js-disabled-ad-blocking-icon {
        display: none!important;
      }
      
      .settings-manager-page {
        pointer-events: none;
      }
    }

    .settings-manager-wrapper._step-4 {
      .settings-manager-page {
        pointer-events: revert;
      }

      .switch__container,
      .settings-manager__content-item {
        cursor: revert;
        pointer-events: revert;
        opacity: 1;
      }

      input,
      .switch__slider,
      #reset-position,
      .settings-manager__text,
      .settings-manager__content-item-back {
        pointer-events: none;
      }
    }
    
    .settings-manager-wrapper:has(._step-1) {
      .settings-manager-icon > svg {
          stroke-width: 0.5px;
          stroke: ${P};
      }
    }  
    
    .settings-manager-wrapper:has(._step-2) {
        .settings-manager__content-item:first-child {
            z-index: 15;
            background: ${V};
            filter: drop-shadow(0px 0px 12px  ${P});
        }
    }  
    .settings-manager-wrapper:has(._step-3) {
        .settings-manager__content-item:nth-child(2) {
            z-index: 15;
            background: ${V};
            filter: drop-shadow(0px 0px 12px  ${P});
        }
    }   
    .settings-manager-wrapper:has(._step-4) {
        .settings-manager-settings-page {
            z-index: 15;
            box-shadow: 0 0 12px 2px ${P};
