    .hidden {
      display: none;
    }
    .disable {
      visibility: hidden;
      pointer-events: none;
    }
    
    .settings-manager-wrapper *,
    .settings-manager-wrapper {
        font-family: "Inter", sans-serif;
        font-size: 12px;
        font-style: normal;
        font-weight: 400;
        line-height: 18px;
        color: ${n0};
        
        margin: 0;
        padding: 0;
        background-color: transparent;
        box-shadow: none;
        width: revert;
        text-decoration: none;
    }

    .settings-manager-wrapper {
        opacity: 0;
        position: fixed;
        width: auto;
        margin: 0;
        padding: 0;
        border-radius: 20px;
        z-index: 10000000;
        direction: ltr;
    }
    
    .settings-manager-wrapper.activated {
      opacity: 1;
    }

    .settings-manager-wrapper.${f} {
      display: none !important;
    }

    .settings-manager-page {
        width: 281px;
      
        &.active {
            opacity: 1;
            z-index: initial;
            pointer-events: initial;
        }
    }

    .active {
        display: block !important;
    }
    
    .nonVisible {
        opacity: 0 !important;
    }

    .settings-manager__content {
        display: flex;
        flex-direction: column;
        background-color: ${p};    
        border-bottom-right-radius: 8px;
        border-bottom-left-radius: 8px;
    }
    
    .settings-manager__ads-count-wrapper {
        padding: 5px 16px;
    }
    
    .settings-manager__ads-count {
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
        background: ${f2};
        padding: 8px 12px;
        border-radius: 6px;
    }

    .settings-manager-toggle-button-wrapper:has(.settings-manager__toggle-button.active) + .settings-manager-menu .settings-manager__ads-count {
        background: ${v2};
    }

    .settings-manager__ads-count-title {
      color: ${p};
      font-weight: 700;
      font-size: 10px;
      line-height: 18px;
      text-align: center;
      text-transform: uppercase;
    }

    .settings-manager__ads-counter {
        color: ${p};
        font-weight: 400;
        font-size: 18px;
        line-height: 30px;
        text-align: center;
        vertical-align: middle;
    }
    
    .settings-manager__content-item {
        transition: background-color 0.3s ease;
        position: relative;
    }
    
    .settings-manager__content-item > :first-child {
        padding: 6px 16px;
        width: 100%;
        display: flex;
        box-sizing: border-box;
        height: 38px;
        align-items: center;
        cursor: pointer;
        justify-content: space-between;
    }

    .settings-manager__content-item:hover {
        background-color: ${V};
    }
    
    .settings-manager__content-item:has(button:disabled) {
        opacity: .3;
        pointer-events: none;
    }

    .settings-manager__content-item:has(.settings-manager__action-button--active:disabled) {
        background-color: #0BBE1D1A !important;
        opacity: 1;
    }

    .settings-manager__content-item:has(input:disabled) {
      .switch__container {
        cursor: default;
      }
        cursor: default;
        &:hover {
          background-color: transparent;
        }
    }

    .settings-manager__action-button {
        width: 100%;
        border: none;
        outline: none;
        text-align: left;
    }

    .settings-manager__text[for="toggle-enabled"] {
        display: inline-flex;
    }

    .settings-manager__action-button svg, 
    .settings-manager__action-button rect {
        width: 18px;
    }

    .settings-manager__action-button svg {
        margin-right: 9px;
        display: none;
    }

    .settings-manager__action-button.show-icon svg {
        display: revert;
    }

    .settings-manager__link-wrapper {
        display: flex;
    }

    .switch__container {
        position: relative;
        display: inline-flex;
        align-items: center;
        width: 100%;
    }

    .switch__slider {
        display: block;
    }

    .switch__checkbox {
        opacity: 0;
        width: 0;
        height: 0;
        position: absolute;
    }

    .switch__slider {
        position: relative;
        width: 36px;
        height: 20px;
        background-color: ${f2};
        border-radius: 12px;
        transition: background-color 0.3s;
        display: inline-block;
    }

    .switch__slider::before {
        content: '';
        position: absolute;
        width: 16px;
        height: 16px;
        background-color: ${p};
        border-radius: 50%;
        top: 50%;
        transform: translateY(-50%);
        left: 1px;
        transition: transform 0.3s;
        border: 1px solid #bababa;
        z-index: 10;
    }

    .switch__checkbox:checked + .switch__slider {
        background-color: ${J};
    }

    .switch__checkbox:checked + .switch__slider::before {
        transform: translate(16px, -50%);
        border-color: ${J};
    }
    
    .switch__slider::after {
        content: '';
        position: absolute;
        width: 40px;
        height: 40px;
        background-color: ${J};
        border-radius: 50%;
        top: 50%;
        transform: translate(-10px, -50%);
        pointer-events: none;
        z-index: 5;
        opacity: 0;
        transition: transform 0.3s ease, opacity 0.3s ease;
    }

    .switch__slider:hover::after {
        opacity: 0.08;
    }

    .switch__checkbox:checked + .switch__slider::after {
        transform: translate(6px, -50%);
    }
    
    .settings-manager__arrow,  .settings-manager__open {
        width: 20px;
        height: 20px;
    }
    
    .switch__container label {
        cursor: pointer;
    }
    
    .switch__container:has(input:disabled) .switch__slider {
        pointer-events: none;
        opacity: 0.3;
    }

    .switch__container:has(input:disabled) label {
        pointer-events: none;
    }

    .${q} {
        position: fixed;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        background: #322f35;
        color: #fff;
        padding: 14px 10px;
        border-radius: 8px;
        font-size: 14px;
        line-height: 21px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        z-index: 1000;
        transition: opacity 0.3s;
        opacity: 1;
    }

   

    .settings-manager-icon {
        display: flex;
        justify-content: flex-start;
        pointer-events: none;
    }

    .settings-manager-menu:has(#howItWorks:not(.hidden)) {
      height: 290px;
    }

    .settings-manager-wrapper .settings-manager-menu:has(.active-settings-page) {
      height: 247px !important;
      transition: 0.5s;
    }
    
    .settings-manager-main-page__animated-contend {
        border-bottom-right-radius: 8px;
        border-bottom-left-radius: 8px;
        overflow: hidden;
    }

    .settings-manager-wrapper[class*="_step-"]:not([class*="_step-finish"])  .settings-manager-menu.active {
        z-index: 15;
        pointer-events: none;
    }

    .settings-manager-wrapper[class*="_step-"]:not([class*="_step-finish"]) .settings-manager__content,
    .settings-manager-wrapper[class*="_step-"]:not([class*="_step-finish"]) .settings-manager-menu__logo {
        background-color: #05172F30;
    }

    .settings-manager-wrapper[class*="_step-"]:not([class*="_step-finish"]) .settings-manager-main-page__animated-contend {
        overflow: revert;
    }

    ._step-4 .settings-manager-main-page {
      display: none;
    }

    ._step-2 .settings-manager-menu,
    ._step-3 .settings-manager-menu,
    ._step-4 .settings-manager-menu {
      display: block !important;
      z-index: 15;
    }

    ._step-2 .settings-manager-menu,
    ._step-3 .settings-manager-menu {
      pointer-events: none;
    }

    ._step-4 .settings-manager-menu {
      pointer-events: revert;
    }
