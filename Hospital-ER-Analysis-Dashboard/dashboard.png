      width: 100%;
      background-color: white;
      border-radius: 4px;
      box-shadow: 0 2px 4px 0 ${F};
      display: none;
      max-height: 200px;
      overflow-y: auto;
      z-index: 15;
      padding: 4px 0;
  }
  
  .custom-select-option {
      position: relative;
      padding: 8px 12px;
      font-size: 14px;
      cursor: pointer;
      display: flex;
      gap: 12px;
  }

  .custom-select-option[data-value="custom"] {
      display: none;
  }
  
  .custom-select-box.open > .custom-select-options {
      display: block;
  }
  
  .custom-select-option:hover {
      background-color: ${s0};
  }
  
  .custom-select-option--active:after {
      content: '';
      display: block;
      width: 20px;
      height: 20px;
      background-image: url('data:image/svg+xml;base64,');
      background-size: contain;
      background-repeat: no-repeat;
  }
  
  .settings-manager-menu:has(.active-settings-page) .settings-manager-main-page {
     position: absolute;
     opacity: 0;
     pointer-events: none;
     transition: .5s;
     height: 220px;
     overflow: hidden;
  }
  .settings-manager-menu:has(.active-settings-page) .settings-manager-main-page .settings-manager-main-page__animated-contend {
    opacity: 0;
  }
  
  .settings-manager__animated-menu-second-part .settings-manager__content-item:last-child,
  .settings-manager__animated-menu-second-part .settings-manager__content-item:last-child .settings-manager__action-button{
    overflow: hidden;
    border-bottom-left-radius: 8px;
    border-bottom-right-radius: 8px;
  }
  
  .settings-manager__animated-menu-second-part {
    border-bottom-left-radius: 8px;
    border-bottom-right-radius: 8px;
  }

  ._step-4 .settings-manager-settings-page {
    border-bottom-left-radius: 8px;
    border-bottom-right-radius: 8px;
    /*overflow: hidden;*/
  }
  
  ._step-4 .settings-manager__animated-menu-second-part .settings-manager__content-item:last-child,
  ._step-4 .settings-manager__animated-menu-second-part .settings-manager__content-item:last-child .settings-manager__action-button {
    overflow: revert !important;
  }

  .highlighted {
    filter: drop-shadow(0px 0px 12px  ${P});
    background-color: ${p};
  }
  
  .settings-manager-main-page__animated-contend:has( > .highlighted) {
    overflow: initial;
  }
`,v0=`
    .settings-manager-settings-page {
        opacity: 0;
    }

    .settings-manager-settings-page .settings-manager__content {
        background: transparent;
    }

    .settings-manager-settings-page
    .settings-manager__animated-menu-first-part,
    .settings-manager-settings-page
    .settings-manager__animated-menu-second-part,
    .settings-manager-settings-page
    .settings-manager__content-item:not(.settings-manager__content-item.settings-manager__content-item-back) {
        background: ${p};
    }

    .settings-manager-settings-page
    .settings-manager__animated-menu-first-part {
        z-index: 1001;
    }

    .settings-manager-settings-page
    .settings-manager__animated-menu-second-part {
      z-index: 1002;
    }

    .active-settings-page.settings-manager-settings-page {
        z-index: 11;
        pointer-events: initial;
        opacity: 1;
    }

    /* === Анимации входа === */
    .active-settings-page .settings-manager__animated-menu-first-part {
        animation: fadeSlideFirstIn 0.4s forwards;
    }

    .active-settings-page .settings-manager__animated-menu-second-part {
        animation: fadeSlideSecondIn 0.4s forwards;
    }

    .settings-manager-menu:has(.settings-manager-main-page.active-main-page)
    .settings-manager__animated-menu-first-part {
        animation: hideSettingsPageFirstPart 0.4s ease-out forwards;
    }

    .settings-manager-menu:has(.settings-manager-main-page.active-main-page)
    .settings-manager__animated-menu-second-part {
        animation: hideSettingsPageSecondPart 0.4s ease-out forwards;
    }

    .settings-manager-menu:has(.settings-manager-main-page.active-main-page) .settings-manager__ads-count-wrapper {
        animation: showBlockedCount 0.2s ease-in forwards;
    }

    .settings-manager-menu:has(.settings-manager-main-page.active-main-page) .settings-manager-main-page__animated-contend {
        animation: showMainPageSettings .7s ease-in forwards;
    }

    @keyframes fadeSlideFirstIn {
        from {
            transform: translateY(40px);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    @keyframes fadeSlideSecondIn {
        from {
            transform: translateY(-5px);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }
    
    @keyframes hideSettingsPageSecondPart {
        from {
            transform: translateY(10px);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    @keyframes hideSettingsPageFirstPart {
        from {
            transform: translateY(0);
            opacity: 1;
        }
        to {
            transform: translateY(80px);
            opacity: 0;
        }
    }

    @keyframes showBlockedCount {
        from {
            transform: translateY(10px);
            opacity: .5;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    @keyframes showMainPageSettings {
        0% {
            transform: translateY(-30px);
            opacity: 0;
        }

        50% {
            transform: translateY(5px);
            opacity: 1;
        }

        75% {
            transform: translateY(-2px);
        }

        100% {
            transform: translateY(0);
        }
    }
`,w0=`
